{
  "name": "agent-starter-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{ts,js}\"",
    "lint:fix": "eslint --fix \"**/*.{ts,js}\"",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "vitest --run",
    "test:watch": "vitest",
    "dev": "pnpm run build && node dist/index.js dev",
    "download-files": "pnpm run build && npx livekit-agents download-files",
    "start": "node dist/index.js start"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@livekit/agents": "^1.4.3",
    "@livekit/agents-plugin-livekit": "^1.4.3",
    "@livekit/agents-plugin-silero": "^1.4.3",
    "@livekit/plugins-ai-coustics": "^0.2.14",
    "chromadb": "^3.4.3",
    "dotenv": "^17.4.1",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
         "onnxruntime-node": "1.24.3",
        "@chroma-core/default-embed>@huggingface/transformers": "4.2.0"
    }
}
}
